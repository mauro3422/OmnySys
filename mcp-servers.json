{
  "mcpServers": {
    "omnysystem": {
      "type": "stdio",
      "command": "node",
      "args": [
        "src/layer-c-memory/mcp-stdio-bridge.js"
      ],
      "cwd": ".",
      "env": {
        "OMNYSYS_DAEMON_URL": "http://127.0.0.1:9999/mcp",
        "OMNYSYS_HEALTH_URL": "http://127.0.0.1:9999/health",
        "OMNYSYS_AUTO_START": "1",
        "OMNYSYS_PROJECT_PATH": "."
      }
    }
  }
}
